# WebSocket server for Flutter app
WS_HOST=0.0.0.0
WS_PORT=8787

# EcoFlow app credentials (required)
ECOFLOW_BASE_URL=https://api.ecoflow.com
ECOFLOW_APP_EMAIL=
ECOFLOW_APP_PASSWORD=

# Device selection (recommended)
# Option A: explicit SN list (comma-separated)
ECOFLOW_DEVICE_SNS=

# Option B: auto-catalog from Open API (optional, but useful to list devices)
ECOFLOW_OPEN_BASE_URL=https://api.ecoflow.com
ECOFLOW_OPEN_ACCESS_KEY=
ECOFLOW_OPEN_SECRET_KEY=
